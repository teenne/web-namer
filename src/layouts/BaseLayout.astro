---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  datePublished?: string;
  jsonLd?: object;
  keywords?: string[];
  noindex?: boolean;
}

const {
  title,
  description = 'Audit and auto-fix Figma layer names against naming standards. CLI generates a reviewable manifest; plugin applies renames safely with rollback.',
  ogImage = '',
  ogType = 'website',
  datePublished,
  jsonLd,
  keywords,
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Halisonworks AS',
  url: 'https://fne.halisonworks.com',
  logo: '',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'NO',
  },
  email: 'privacy@halisonworks.com',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:locale" content="en_US" />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}
    {datePublished && <meta property="article:published_time" content={datePublished} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />}

    <!-- Theme -->
    <meta name="theme-color" content="#0d99ff" />

    <!-- Organization JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

    <!-- Additional JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- PostHog Analytics (only when configured) -->
    {import.meta.env.PUBLIC_POSTHOG_KEY && (
      <script
        is:inline
        define:vars={{ phKey: import.meta.env.PUBLIC_POSTHOG_KEY }}
      >
        window.__POSTHOG_KEY = phKey;
      </script>
    )}
  </head>
  <body class="min-h-screen bg-[#f5f5f5]">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-white focus:outline-none">
      Skip to main content
    </a>
    <slot />
    <CookieBanner />
  </body>
</html>
