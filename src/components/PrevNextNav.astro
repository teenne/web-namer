---
interface NavItem {
  title: string;
  href: string;
}

interface Props {
  prev?: NavItem;
  next?: NavItem;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav
    class="mt-10 flex flex-col gap-4 border-t border-primary-200 pt-8 sm:flex-row sm:justify-between"
    aria-label="Post navigation"
  >
    <!-- Previous -->
    <div class="flex-1">
      {prev ? (
        <a
          href={prev.href}
          class="group flex max-w-sm flex-col gap-1 rounded-xl border border-primary-200 p-4 transition-shadow hover:shadow-md"
          rel="prev"
        >
          <span class="flex items-center gap-1 text-xs font-medium text-primary-400 group-hover:text-accent-600">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Previous
          </span>
          <span class="font-heading text-sm font-semibold text-primary-900 group-hover:text-accent-600 line-clamp-2">
            {prev.title}
          </span>
        </a>
      ) : (
        <span />
      )}
    </div>

    <!-- Next -->
    <div class="flex flex-1 justify-end">
      {next && (
        <a
          href={next.href}
          class="group flex max-w-sm flex-col items-end gap-1 rounded-xl border border-primary-200 p-4 transition-shadow hover:shadow-md"
          rel="next"
        >
          <span class="flex items-center gap-1 text-xs font-medium text-primary-400 group-hover:text-accent-600">
            Next
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
          <span class="font-heading text-sm font-semibold text-primary-900 group-hover:text-accent-600 line-clamp-2 text-right">
            {next.title}
          </span>
        </a>
      )}
    </div>
  </nav>
)}
