---
interface Tier {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  highlighted?: boolean;
}

interface Props {
  tiers: Tier[];
  productSlug?: string;
}

const { tiers, productSlug } = Astro.props;
---

<section class="py-16 px-4">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-2 lg:grid-cols-3">
      {tiers.map((tier) => (
        <div
          class:list={[
            'relative rounded-xl border p-8',
            tier.highlighted
              ? 'border-2 border-accent-500 shadow-lg'
              : 'border-gray-200 dark:border-primary-700',
          ]}
        >
          {tier.highlighted && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent-500 px-4 py-1 text-xs font-semibold text-white">
              Most popular
            </span>
          )}

          <h3 class="font-heading text-xl font-bold text-gray-900 dark:text-white">{tier.name}</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{tier.description}</p>

          <div class="mt-6">
            <span class="text-4xl font-bold text-gray-900 dark:text-white">{tier.price}</span>
            {tier.period && (
              <span class="text-base text-gray-500 dark:text-gray-400">/{tier.period}</span>
            )}
          </div>

          <ul class="mt-8 space-y-3">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-green-600"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={tier.ctaHref}
            class:list={[
              'mt-8 block w-full rounded-lg py-3 text-center font-semibold transition-colors duration-200',
              tier.highlighted
                ? 'bg-accent-500 text-white hover:bg-accent-600'
                : 'border border-gray-300 text-gray-800 hover:border-gray-400 hover:bg-gray-50 dark:border-primary-600 dark:text-gray-200 dark:hover:border-primary-500 dark:hover:bg-primary-800',
            ]}
            data-track="cta_click"
            data-label={tier.ctaText}
            data-location={productSlug ? `pricing-${productSlug}` : 'pricing'}
          >
            {tier.ctaText}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
