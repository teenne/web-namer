---
/**
 * PostHog Analytics Component
 *
 * Drop this into src/components/PostHog.astro in your web-master template.
 * Then include it in BaseLayout.astro inside the <head> tag.
 *
 * It automatically:
 * - Derives site_name from Astro.site (set in astro.config.mjs)
 * - Sets site_type via prop (defaults to "website")
 * - Skips tracking on localhost / dev ports
 * - Registers site_name and site_type as super properties on every event
 * - Registers entity as a group property for filtering by business entity
 */

interface Props {
  /** "website" for marketing sites, "webapp" for authenticated apps */
  siteType?: "website" | "webapp";
  /** Override the auto-detected site name (defaults to domain from Astro.site) */
  siteName?: string;
  /** Business entity that owns this site, e.g. "BAS Trust Systems", "Halisonworks" */
  entity?: string;
}

const {
  siteType = "website",
  siteName,
  entity,
} = Astro.props;

// Derive domain from astro.config.mjs `site` value
const domain = Astro.site ? new URL(Astro.site).hostname : "";
const resolvedSiteName = siteName || domain;
---

<!-- PostHog Analytics -->
<script
  is:inline
  data-site-name={resolvedSiteName}
  data-site-type={siteType}
  data-entity={entity || ""}
>
  // Skip tracking in development (localhost, 127.0.0.1, or custom dev ports)
  (function () {
    var host = window.location.hostname;
    var port = window.location.port;
    if (
      host === "localhost" ||
      host === "127.0.0.1" ||
      (port && parseInt(port) >= 4000 && parseInt(port) <= 5200)
    ) {
      return;
    }

    // Get config from data attributes
    var script = document.currentScript;
    var siteName = script.getAttribute("data-site-name");
    var siteType = script.getAttribute("data-site-type");
    var entity = script.getAttribute("data-entity");

