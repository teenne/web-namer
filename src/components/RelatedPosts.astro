---
interface RelatedPost {
  title: string;
  href: string;
  description?: string;
  date?: Date;
}

interface Props {
  posts: RelatedPost[];
  heading?: string;
}

const { posts, heading = 'Related Articles' } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-12 border-t border-primary-200 pt-10">
    <h2 class="mb-6 font-heading text-xl font-semibold text-primary-900">{heading}</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a
          href={post.href}
          class="group block rounded-xl border border-primary-200 p-5 transition-shadow hover:shadow-md"
        >
          <h3 class="font-heading text-base font-semibold text-primary-900 group-hover:text-accent-600 line-clamp-2">
            {post.title}
          </h3>
          {post.description && (
            <p class="mt-2 text-sm text-primary-500 line-clamp-2">{post.description}</p>
          )}
          {post.date && (
            <time
              datetime={post.date.toISOString()}
              class="mt-3 block text-xs text-primary-400"
            >
              {new Intl.DateTimeFormat('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              }).format(post.date)}
            </time>
          )}
        </a>
      ))}
    </div>
  </section>
)}
