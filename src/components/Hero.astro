---
interface Props {
  headline: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  variant?: 'default' | 'dark';
}

const {
  headline,
  subheadline,
  ctaText,
  ctaHref = '#',
  secondaryCtaText,
  secondaryCtaHref = '#',
  variant = 'default',
} = Astro.props;

const isDark = variant === 'dark';
---

<section
  class:list={[
    'px-4 py-20 sm:px-6 md:py-28 lg:px-8 lg:py-36',
    isDark
      ? 'bg-gradient-to-br from-primary-900 via-primary-950 to-primary-900 text-white'
      : 'bg-primary-50 text-primary-900 dark:bg-primary-900 dark:text-white',
  ]}
>
  <div class="mx-auto max-w-4xl text-center">
    <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
      {headline}
    </h1>

    {subheadline && (
      <p
        class:list={[
          'mx-auto mt-6 max-w-2xl text-lg md:text-xl',
          isDark ? 'text-primary-300' : 'text-primary-500 dark:text-primary-400',
        ]}
      >
        {subheadline}
      </p>
    )}

    {(ctaText || secondaryCtaText) && (
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        {ctaText && (
          <a
            href={ctaHref}
            class:list={[
              'inline-flex items-center rounded-md px-6 py-3 text-base font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500',
              isDark
                ? 'bg-accent-500 text-white hover:bg-accent-400'
                : 'bg-accent-500 text-white hover:bg-accent-600',
            ]}
            data-track="cta_click"
          >
            {ctaText}
          </a>
        )}

        {secondaryCtaText && (
          <a
            href={secondaryCtaHref}
            class:list={[
              'inline-flex items-center rounded-md border-2 px-6 py-3 text-base font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500',
              isDark
                ? 'border-white/30 text-white hover:border-white hover:bg-white/10'
                : 'border-primary-300 text-primary-700 hover:border-primary-400 hover:bg-primary-100 dark:border-primary-600 dark:text-primary-300 dark:hover:border-primary-500 dark:hover:bg-primary-800',
            ]}
            data-track="cta_click"
          >
            {secondaryCtaText}
          </a>
        )}
      </div>
    )}
  </div>
</section>
