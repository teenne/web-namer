---
interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  name: string;
  bio?: string;
  image?: string;
  social?: SocialLink[];
}

const { name, bio, image, social } = Astro.props;
---

<div class="mt-8 flex items-start gap-4 rounded-lg border border-primary-200 p-6">
  <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full bg-primary-200">
    {image && (
      <img src={image} alt={name} class="h-full w-full object-cover" loading="lazy" decoding="async" />
    )}
  </div>
  <div>
    <p class="font-heading text-base font-semibold text-primary-900">{name}</p>
    {bio && <p class="mt-1 text-sm text-primary-500">{bio}</p>}
    {social && social.length > 0 && (
      <div class="mt-2 flex gap-3">
        {social.map((link) => (
          <a
            href={link.url}
            class="text-sm font-medium text-accent-600 transition-colors hover:text-accent-500"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.platform}
          </a>
        ))}
      </div>
    )}
  </div>
</div>
