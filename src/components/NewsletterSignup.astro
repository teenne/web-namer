---
interface Props {
  heading?: string;
  description?: string;
  buttonText?: string;
}

const {
  heading = "Stay in the loop",
  description = "Get the latest articles and updates.",
  buttonText = "Subscribe",
} = Astro.props;
---

<div class="newsletter-signup mx-auto max-w-lg rounded-2xl bg-primary-50 p-8 dark:bg-primary-900">
  <div class="text-center">
    <h2 class="font-heading text-2xl font-bold text-gray-900 dark:text-white">{heading}</h2>
    {description && (
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{description}</p>
    )}
  </div>

  <form
    class="mt-6 flex flex-col gap-3 sm:flex-row"
    data-newsletter-form
  >
    <label class="sr-only" for="newsletter-email">Email address</label>
    <input
      id="newsletter-email"
      type="email"
      name="email"
      required
      placeholder="you@example.com"
      autocomplete="email"
      class="flex-1 rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 placeholder:text-gray-400 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/20 dark:border-primary-600 dark:bg-primary-800 dark:text-white dark:placeholder:text-gray-500"
    />
    <button
      type="submit"
      class="rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-accent-600 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
    >
      {buttonText}
    </button>
  </form>

  <p class="mt-2 text-center text-xs text-gray-400">
    By subscribing, you agree to our <a href="/privacy" class="underline hover:text-gray-600">privacy policy</a>.
  </p>

  <div
    class="mt-3 text-center text-sm"
    data-newsletter-status
    aria-live="polite"
  ></div>
</div>

<script>
  function initNewsletterForms(): void {
    const forms = document.querySelectorAll<HTMLFormElement>("[data-newsletter-form]");

    forms.forEach((form) => {
      form.addEventListener("submit", async (e: SubmitEvent) => {
        e.preventDefault();

        const statusEl = form
          .closest(".newsletter-signup")
          ?.querySelector<HTMLDivElement>("[data-newsletter-status]");
        if (!statusEl) return;

        const formData = new FormData(form);
        const email = formData.get("email") as string;
        if (!email) return;

        const keyMeta = document.querySelector<HTMLMetaElement>(
          'meta[name="buttondown-key"]'
        );

        if (!keyMeta?.content) {
          window.location.href = `mailto:?subject=Subscribe&body=Please subscribe me: ${encodeURIComponent(email)}`;
          return;
        }

        const submitBtn = form.querySelector<HTMLButtonElement>(
          'button[type="submit"]'
        );
        if (submitBtn) submitBtn.disabled = true;

        try {
          const res = await fetch(
            "https://api.buttondown.email/v1/subscribers",
            {
              method: "POST",
              headers: {
                Authorization: `Token ${keyMeta.content}`,
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ email }),
            }
          );

          if (res.ok || res.status === 201) {
            statusEl.textContent = "Thanks for subscribing!";
            statusEl.className = "mt-3 text-center text-sm text-green-600";
            form.reset();

            if (typeof window.gtag === "function") {
              window.gtag("event", "newsletter_signup", {
                event_category: "engagement",
              });
            }
            document.dispatchEvent(
              new CustomEvent("newsletter:subscribed", { detail: { email } })
            );
          } else {
            const data = await res.json().catch(() => null);
            const message =
              data?.detail || data?.email?.[0] || "Something went wrong. Please try again.";
            statusEl.textContent = message;
            statusEl.className = "mt-3 text-center text-sm text-red-600";
          }
        } catch {
          statusEl.textContent = "Network error. Please try again.";
          statusEl.className = "mt-3 text-center text-sm text-red-600";
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initNewsletterForms);
  initNewsletterForms();

  declare global {
    interface Window {
      gtag?: (...args: unknown[]) => void;
    }
  }
</script>
