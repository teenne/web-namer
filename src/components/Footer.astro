---
const currentYear = new Date().getFullYear();

interface FooterLink {
  label: string;
  href: string;
}

// TODO: Replace with actual service/product links
const servicesLinks: FooterLink[] = [
  { label: 'Service One', href: '/services/service-one' },
  { label: 'Service Two', href: '/services/service-two' },
  { label: 'Service Three', href: '/services/service-three' },
  { label: 'Service Four', href: '/services/service-four' },
];

const companyLinks: FooterLink[] = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Terms & Conditions', href: '/terms' },
  { label: 'Blog', href: '/blog' },
];
---

<footer class="bg-primary-950 text-white" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Brand -->
      <div>
        <h2 class="font-heading text-xl font-bold">
          Brand {/* TODO: Replace with brand name */}
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-primary-300">
          {/* TODO: Replace with brand tagline or short description */}
          Your trusted partner for quality solutions. We deliver excellence through innovation and dedication.
        </p>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-primary-300">
          Services
        </h3>
        <ul class="mt-4 space-y-2" role="list">
          {servicesLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-primary-400 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Company -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-primary-300">
          Company
        </h3>
        <ul class="mt-4 space-y-2" role="list">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-primary-400 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact Info -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-primary-300">
          Contact
        </h3>
        <ul class="mt-4 space-y-3" role="list">
          <!-- Location -->
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-primary-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm text-primary-400">
              {/* TODO: Replace with actual address */}
              123 Main Street, City, ST 12345
            </span>
          </li>

          <!-- Phone -->
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-primary-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a
              href="tel:+10000000000"
              class="text-sm text-primary-400 transition-colors hover:text-white"
            >
              {/* TODO: Replace with actual phone number */}
              (000) 000-0000
            </a>
          </li>

          <!-- Email -->
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-primary-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a
              href="mailto:info@example.com"
              class="text-sm text-primary-400 transition-colors hover:text-white"
            >
              {/* TODO: Replace with actual email */}
              info@example.com
            </a>
          </li>

          <!-- Hours -->
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-primary-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm text-primary-400">
              {/* TODO: Replace with actual business hours */}
              Mon–Fri: 9:00 AM – 5:00 PM
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-primary-800 pt-8">
      <p class="text-center text-sm text-primary-500">
        &copy; {currentYear} Brand. All rights reserved.
        {/* TODO: Replace with actual org registration number if applicable */}
        <span class="mx-2">|</span>
        Org. No: 000 000 000
      </p>
    </div>
  </div>
</footer>
