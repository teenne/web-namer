---
const currentYear = new Date().getFullYear();

interface FooterLink {
  label: string;
  href: string;
}

const productLinks: FooterLink[] = [
  { label: 'Documentation', href: '/docs' },
  { label: 'GitHub', href: 'https://github.com/halisonworks/fne' },
  { label: 'Figma Community', href: '#' },
];

const legalLinks: FooterLink[] = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
];
---

<footer class="bg-primary-900 text-white" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Brand -->
      <div>
        <h2 class="font-mono text-xl font-bold">FNE</h2>
        <p class="mt-3 text-sm leading-relaxed text-primary-400">
          Design files should be machine-readable and human-understandable. Default names serve neither purpose.
        </p>
      </div>

      <!-- Column 2: Product -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-400">
          Product
        </h3>
        <ul class="mt-4 space-y-2" role="list">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-primary-400 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Legal -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-400">
          Legal
        </h3>
        <ul class="mt-4 space-y-2" role="list">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-primary-400 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-400">
          Contact
        </h3>
        <ul class="mt-4 space-y-3" role="list">
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:privacy@halisonworks.com" class="text-sm text-primary-400 transition-colors hover:text-white">
              privacy@halisonworks.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-primary-800 pt-8">
      <p class="text-center text-sm text-primary-500">
        &copy; {currentYear} Halisonworks AS. All rights reserved.
      </p>
    </div>
  </div>
</footer>
