---
interface Testimonial {
  quote: string;
  author: string;
  role?: string;
  company?: string;
}

interface Props {
  items: Testimonial[];
  sectionTitle?: string;
}

const { items, sectionTitle = 'What Our Clients Say' } = Astro.props;
---

<section class="bg-primary-50 px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-center font-heading text-3xl font-bold text-primary-900">{sectionTitle}</h2>
    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <blockquote class="rounded-xl bg-white p-6 shadow-sm">
          <svg class="h-8 w-8 text-accent-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
          </svg>
          <p class="mt-4 text-primary-600">{item.quote}</p>
          <footer class="mt-4 border-t border-primary-100 pt-4">
            <p class="font-semibold text-primary-900">{item.author}</p>
            {(item.role || item.company) && (
              <p class="text-sm text-primary-500">
                {item.role}{item.role && item.company && ' at '}{item.company}
              </p>
            )}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
