---
interface Props {
  headline: string;
  ctaText: string;
  ctaHref: string;
  variant?: 'default' | 'accent';
}

const {
  headline,
  ctaText,
  ctaHref,
  variant = 'default',
} = Astro.props;

const isAccent = variant === 'accent';
---

<section
  class:list={[
    'px-4 py-16 sm:px-6 md:py-20 lg:px-8',
    isAccent ? 'bg-accent-500' : 'bg-primary-50 dark:bg-primary-900',
  ]}
>
  <div class="mx-auto max-w-3xl text-center">
    <h2
      class:list={[
        'font-heading text-2xl font-bold md:text-3xl',
        isAccent ? 'text-white' : 'text-primary-900 dark:text-white',
      ]}
    >
      {headline}
    </h2>

    <div class="mt-8">
      <a
        href={ctaHref}
        class:list={[
          'inline-flex items-center rounded-md px-6 py-3 text-base font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2',
          isAccent
            ? 'bg-white text-accent-600 hover:bg-primary-50 focus-visible:outline-white'
            : 'bg-accent-500 text-white hover:bg-accent-600 focus-visible:outline-accent-500',
        ]}
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
