---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Privacy Policy | Brand"
  description="Read our privacy policy to understand how we handle your data."
>
  <Header />
  <main>
    <section class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="font-heading text-4xl font-bold text-primary-900">Privacy Policy</h1>
        <p class="mt-4 text-sm text-primary-500">Last updated: January 1, 2025</p>
        <div class="prose prose-primary mt-8 max-w-none">
          <h2>1. Information We Collect</h2>
          <p>TODO: Describe what personal information you collect (name, email, etc.).</p>

          <h2>2. How We Use Your Information</h2>
          <p>TODO: Explain how collected information is used.</p>

          <h2>3. Cookies</h2>
          <p>TODO: Describe your cookie usage and tracking practices.</p>

          <h2>4. Third-Party Services</h2>
          <p>TODO: List third-party services (analytics, form processing, etc.) and how they handle data.</p>

          <h2>5. Data Retention</h2>
          <p>TODO: Explain how long you retain personal data.</p>

          <h2>6. Your Rights</h2>
          <p>TODO: Describe user rights (access, deletion, portability, etc.).</p>

          <h2>7. Contact Us</h2>
          <p>TODO: Provide contact information for privacy-related inquiries.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
