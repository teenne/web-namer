---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatsBar from '../components/StatsBar.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';

// TODO: Replace with brand-specific feature content
const features = [
  {
    title: 'Feature One',
    description: 'TODO: Describe your first key feature or service offering. Focus on the benefit to the customer.',
    icon: '<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" stroke-linecap="round" stroke-linejoin="round" /></svg>',
  },
  {
    title: 'Feature Two',
    description: 'TODO: Describe your second key feature or service offering. Focus on the benefit to the customer.',
    icon: '<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3" /><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>',
  },
  {
    title: 'Feature Three',
    description: 'TODO: Describe your third key feature or service offering. Focus on the benefit to the customer.',
    icon: '<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" /></svg>',
  },
  {
    title: 'Feature Four',
    description: 'TODO: Describe your fourth key feature or service offering. Focus on the benefit to the customer.',
    icon: '<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round" /></svg>',
  },
];

const stats = [
  { value: '50+', label: 'Projects Delivered' },
  { value: '10+', label: 'Years Experience' },
  { value: '99%', label: 'Client Satisfaction' },
  { value: '24/7', label: 'Support' },
];
---

<BaseLayout
  title="Home | Brand"
  description="TODO: Write your homepage meta description. Keep it under 160 characters and include your primary keyword."
>
  <Header />

  <main>
    <Hero
      headline="We build products that solve real problems"
      subheadline="TODO: Your value proposition here"
      ctaText="See Our Work"
      ctaHref="/portfolio"
      secondaryCtaText="How We Work"
      secondaryCtaHref="/process"
      variant="dark"
    />

    <FeatureGrid
      sectionTitle="What We Do"
      sectionSubtitle="TODO: Brief summary of your core offerings"
      features={features}
    />

    <StatsBar stats={stats} />

    <CTABanner
      headline="Ready to get started?"
      ctaText="Get in Touch"
      ctaHref="/contact"
      variant="accent"
    />
  </main>

  <Footer />
</BaseLayout>
