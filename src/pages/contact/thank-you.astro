---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Thank You | Brand"
  description="Thank you for contacting us. We'll be in touch soon."
>
  <Header />

  <main>
    <section class="flex min-h-[60vh] items-center justify-center px-4 py-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-lg text-center">
        <!-- Success Icon -->
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
          <svg
            class="h-8 w-8 text-green-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="mt-6 font-heading text-3xl font-bold text-primary-900 dark:text-white md:text-4xl">
          Thank you!
        </h1>
        <p class="mt-4 text-lg text-primary-500 dark:text-primary-400">
          We've received your message and will be in touch soon. We typically respond within one business day.
        </p>

        <div class="mt-8">
          <a
            href="/"
            class="inline-flex items-center rounded-md bg-accent-500 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-accent-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
          >
            Back to Home
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
