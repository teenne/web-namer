---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

// TODO: Replace with actual business details
const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Brand', // TODO: Replace with business name
  description: 'TODO: Brief description of your business',
  url: Astro.site?.href ?? 'https://example.com', // TODO: Update with production URL
  telephone: '+10000000000', // TODO: Replace with actual phone number
  email: 'info@example.com', // TODO: Replace with actual email
  address: {
    '@type': 'PostalAddress',
    streetAddress: '123 Main Street', // TODO: Replace with actual street address
    addressLocality: 'City', // TODO: Replace with actual city
    addressRegion: 'ST', // TODO: Replace with actual state/region
    postalCode: '12345', // TODO: Replace with actual postal code
    addressCountry: 'US', // TODO: Replace with actual country code
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
};

// TODO: Replace with your actual service categories
const serviceOptions = [
  {
    group: 'Consulting',
    options: [
      { value: 'strategy', label: 'Strategy & Planning' },
      { value: 'audit', label: 'Technical Audit' },
    ],
  },
  {
    group: 'Development',
    options: [
      { value: 'web', label: 'Web Development' },
      { value: 'app', label: 'Application Development' },
    ],
  },
];
---

<BaseLayout
  title="Contact Us | Brand"
  description="TODO: Write a contact page meta description. Include your location and primary service."
  jsonLd={localBusinessJsonLd}
>
  <Header />

  <main>
    <!-- Page Header -->
    <section class="bg-primary-50 px-4 py-16 sm:px-6 lg:px-8 dark:bg-primary-900">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-heading text-4xl font-bold text-primary-900 dark:text-white md:text-5xl">
          Contact Us
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-500 dark:text-primary-400">
          {/* TODO: Replace with your contact page intro */}
          Have a project in mind? We'd love to hear from you. Send us a message and we'll respond as soon as possible.
        </p>
      </div>
    </section>

    <!-- Two-column Layout -->
    <section class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-5">
        <!-- Left: Contact Form -->
        <div class="lg:col-span-3">
          <ContactForm
            formTitle="Send Us a Message"
            showCompanyField={true}
            serviceOptions={serviceOptions}
          />
        </div>

        <!-- Right: Contact Info Card -->
        <div class="lg:col-span-2">
          <div class="rounded-2xl bg-primary-50 p-8 dark:bg-primary-900">
            <h2 class="font-heading text-xl font-bold text-primary-900 dark:text-white">
              Get in Touch
            </h2>
            <p class="mt-2 text-sm text-primary-500 dark:text-primary-400">
              {/* TODO: Replace with your contact card intro */}
              Prefer to reach out directly? Here's how you can find us.
            </p>

            <ul class="mt-8 space-y-6" role="list">
              <!-- Location -->
              <li class="flex items-start gap-4">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-accent-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <div>
                  <span class="block text-sm font-semibold text-primary-900 dark:text-white">Address</span>
                  <span class="mt-1 block text-sm text-primary-500 dark:text-primary-400">
                    {/* TODO: Replace with actual address */}
                    123 Main Street<br />
                    City, ST 12345
                  </span>
                </div>
              </li>

              <!-- Phone -->
              <li class="flex items-start gap-4">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-accent-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <div>
                  <span class="block text-sm font-semibold text-primary-900 dark:text-white">Phone</span>
                  <a
                    href="tel:+10000000000"
                    class="mt-1 block text-sm text-primary-500 transition-colors hover:text-accent-500 dark:text-primary-400"
                  >
                    {/* TODO: Replace with actual phone number */}
                    (000) 000-0000
                  </a>
                </div>
              </li>

              <!-- Email -->
              <li class="flex items-start gap-4">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-accent-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <div>
                  <span class="block text-sm font-semibold text-primary-900 dark:text-white">Email</span>
                  <a
                    href="mailto:info@example.com"
                    class="mt-1 block text-sm text-primary-500 transition-colors hover:text-accent-500 dark:text-primary-400"
                  >
                    {/* TODO: Replace with actual email */}
                    info@example.com
                  </a>
                </div>
              </li>

              <!-- Hours -->
              <li class="flex items-start gap-4">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-accent-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <span class="block text-sm font-semibold text-primary-900 dark:text-white">Business Hours</span>
                  <span class="mt-1 block text-sm text-primary-500 dark:text-primary-400">
                    {/* TODO: Replace with actual business hours */}
                    Mon&ndash;Fri: 9:00 AM &ndash; 5:00 PM
                  </span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
