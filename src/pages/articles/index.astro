---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';

const articles = await getCollection('articles', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

// Sort by date descending
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Extract featured articles
const featuredArticles = articles.filter((a) => a.data.featured);

// Extract unique types for filter buttons
const articleTypes = ['all', ...new Set(articles.map((a) => a.data.type))] as const;
---

<BaseLayout
  title="Articles | Brand"
  description="TODO: Write a meta description for your articles listing page."
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="bg-primary-50 px-4 py-16 sm:px-6 lg:px-8 dark:bg-primary-900">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-heading text-4xl font-bold text-primary-900 dark:text-white md:text-5xl">
          Articles
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-500 dark:text-primary-400">
          Insights, case studies, and guides
        </p>
      </div>
    </section>

    <!-- Featured Articles -->
    {featuredArticles.length > 0 && (
      <section class="border-b border-primary-200 px-4 py-12 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <h2 class="mb-6 font-heading text-xl font-semibold text-primary-900">Featured</h2>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            {await Promise.all(featuredArticles.map(async (article) => {
              const { remarkPluginFrontmatter } = await render(article);
              return (
                <BlogCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  href={`/articles/${article.id}`}
                  category={article.data.type}
                  image={article.data.image}
                  imageAlt={article.data.image_alt}
                  readingTime={remarkPluginFrontmatter?.minutesRead}
                />
              );
            }))}
          </div>
        </div>
      </section>
    )}

    <!-- Filter + Grid Section -->
    <section class="px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <!-- Filter Buttons -->
        <div class="mb-10 flex flex-wrap justify-center gap-2" role="tablist" aria-label="Filter articles by type">
          {articleTypes.map((type) => (
            <button
              type="button"
              class:list={[
                'filter-btn rounded-full px-5 py-2 text-sm font-medium transition-colors',
                type === 'all'
                  ? 'bg-accent-500 text-white'
                  : 'bg-primary-100 text-primary-700 hover:bg-primary-200 dark:bg-primary-800 dark:text-primary-300 dark:hover:bg-primary-700',
              ]}
              data-filter={type}
              role="tab"
              aria-selected={type === 'all' ? 'true' : 'false'}

            >
              {type === 'all'
                ? 'All'
                : type === 'case-study'
                  ? 'Case Studies'
                  : type === 'whitepaper'
                    ? 'Whitepapers'
                    : 'Guides'}
            </button>
          ))}
        </div>

        <!-- Articles Grid -->
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3" id="articles-grid">
          {await Promise.all(articles.map(async (article) => {
            const { remarkPluginFrontmatter } = await render(article);
            return (
              <div class="article-item" data-type={article.data.type}>
                <BlogCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  href={`/articles/${article.id}`}
                  category={article.data.type}
                  image={article.data.image}
                  readingTime={remarkPluginFrontmatter?.minutesRead}
                />
              </div>
            );
          }))}
        </div>

        <!-- Empty State -->
        <p class="mt-8 hidden text-center text-primary-500 dark:text-primary-400" id="no-articles">
          No articles found for this filter.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  function initFilters(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.article-item');
    const noArticles = document.getElementById('no-articles');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        // Update button states
        buttons.forEach((b) => {
          b.classList.remove('bg-accent-500', 'text-white');
          b.classList.add('bg-primary-100', 'text-primary-700');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.remove('bg-primary-100', 'text-primary-700');
        btn.classList.add('bg-accent-500', 'text-white');
        btn.setAttribute('aria-selected', 'true');

        // Filter items
        let visibleCount = 0;
        items.forEach((item) => {
          const matches = filter === 'all' || item.dataset.type === filter;
          item.style.display = matches ? '' : 'none';
          if (matches) visibleCount++;
        });

        // Toggle empty state
        if (noArticles) {
          noArticles.classList.toggle('hidden', visibleCount > 0);
        }
      });
    });
  }

  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>
