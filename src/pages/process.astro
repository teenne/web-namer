---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';

const steps = [
  { number: 1, title: 'Discovery', description: 'We start by understanding your business, goals, and target audience through in-depth consultation.' },
  { number: 2, title: 'Strategy', description: 'Based on our findings, we develop a comprehensive strategy tailored to your objectives.' },
  { number: 3, title: 'Design', description: 'Our design team creates beautiful, functional designs that align with your brand identity.' },
  { number: 4, title: 'Development', description: 'We build your solution using modern technologies and best practices for performance and scalability.' },
  { number: 5, title: 'Testing', description: 'Rigorous testing ensures everything works perfectly across all devices and browsers.' },
  { number: 6, title: 'Launch & Support', description: 'We handle the launch and provide ongoing support to ensure continued success.' },
];
---

<BaseLayout
  title="Our Process | Brand"
  description="Learn about our proven process for delivering exceptional results."
>
  <Header />
  <main>
    <section class="bg-primary-50 px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-heading text-4xl font-bold text-primary-900 md:text-5xl">How We Work</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-500">
          Our proven process ensures consistent, high-quality results.
        </p>
      </div>
    </section>

    <section class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="relative">
          <div class="absolute left-8 top-0 hidden h-full w-0.5 bg-primary-200 md:block" aria-hidden="true"></div>
          <div class="space-y-12">
            {steps.map((step) => (
              <div class="relative flex gap-6">
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-accent-500 text-xl font-bold text-white">
                  {step.number}
                </div>
                <div class="pt-3">
                  <h3 class="font-heading text-xl font-semibold text-primary-900">{step.title}</h3>
                  <p class="mt-2 text-primary-500">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <CTABanner
      headline="Ready to start your project?"
      ctaText="Get in Touch"
      ctaHref="/contact"
      variant="accent"
    />
  </main>
  <Footer />
</BaseLayout>
