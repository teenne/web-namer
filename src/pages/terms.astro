---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Terms & Conditions | Brand"
  description="Read our terms and conditions."
>
  <Header />
  <main>
    <section class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="font-heading text-4xl font-bold text-primary-900">Terms &amp; Conditions</h1>
        <p class="mt-4 text-sm text-primary-500">Last updated: January 1, 2025</p>
        <div class="prose prose-primary mt-8 max-w-none">
          <h2>1. Agreement to Terms</h2>
          <p>TODO: Write your terms and conditions. By accessing this website, you agree to be bound by these terms of service.</p>

          <h2>2. Use License</h2>
          <p>TODO: Describe permitted use of your website and services.</p>

          <h2>3. Disclaimer</h2>
          <p>TODO: Add your disclaimer information.</p>

          <h2>4. Limitations</h2>
          <p>TODO: Describe limitations of liability.</p>

          <h2>5. Revisions</h2>
          <p>TODO: Describe how terms may be revised.</p>

          <h2>6. Governing Law</h2>
          <p>TODO: Specify applicable jurisdiction and governing law.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
