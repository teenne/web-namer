---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import CTABanner from '../../components/CTABanner.astro';
import Footer from '../../components/Footer.astro';

const products = await getCollection('products', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
products.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Products | Brand"
  description="Discover our range of products designed to help you succeed."
>
  <Header />
  <main>
    <section class="bg-primary-50 px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-heading text-4xl font-bold text-primary-900 md:text-5xl">Our Products</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-500">
          Tools and solutions built to solve real problems.
        </p>
      </div>
    </section>

    <section class="px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {products.map((product) => (
            <a href={`/products/${product.id}`} class="group overflow-hidden rounded-xl border border-primary-200 transition-shadow hover:shadow-lg">
              {product.data.image ? (
                <div class="aspect-video overflow-hidden">
                  <img src={product.data.image} alt={product.data.title} class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" decoding="async" />
                </div>
              ) : (
                <div class="aspect-video bg-primary-100"></div>
              )}
              <div class="p-5">
                <h3 class="font-heading text-lg font-semibold text-primary-900 group-hover:text-accent-600">{product.data.title}</h3>
                <p class="mt-2 text-sm text-primary-500">{product.data.description}</p>
                {product.data.price && (
                  <p class="mt-3 text-lg font-bold text-accent-600">{product.data.price}</p>
                )}
                <span class="mt-3 inline-flex items-center text-sm font-medium text-accent-600">
                  Learn more →
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTABanner
      headline="Need help choosing?"
      ctaText="Talk to Us"
      ctaHref="/contact"
      variant="accent"
    />
  </main>
  <Footer />
</BaseLayout>
