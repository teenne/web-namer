---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';

const projects = [
  { title: 'Project One', description: 'TODO: Describe this project and the results achieved.', tags: ['Web Design', 'Development'] },
  { title: 'Project Two', description: 'TODO: Describe this project and the results achieved.', tags: ['Branding', 'Strategy'] },
  { title: 'Project Three', description: 'TODO: Describe this project and the results achieved.', tags: ['Mobile App', 'UI/UX'] },
  { title: 'Project Four', description: 'TODO: Describe this project and the results achieved.', tags: ['E-commerce', 'Development'] },
  { title: 'Project Five', description: 'TODO: Describe this project and the results achieved.', tags: ['Web Design', 'SEO'] },
  { title: 'Project Six', description: 'TODO: Describe this project and the results achieved.', tags: ['Branding', 'Development'] },
];
---

<BaseLayout
  title="Portfolio | Brand"
  description="Explore our work and see how we've helped clients achieve their goals."
>
  <Header />
  <main>
    <section class="bg-primary-50 px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-heading text-4xl font-bold text-primary-900 md:text-5xl">Our Work</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-500">
          A selection of projects we're proud of.
        </p>
      </div>
    </section>

    <section class="px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <div class="group overflow-hidden rounded-xl border border-primary-200 transition-shadow hover:shadow-lg">
              <div class="aspect-video bg-primary-100"></div>
              <div class="p-5">
                <h3 class="font-heading text-lg font-semibold text-primary-900">{project.title}</h3>
                <p class="mt-2 text-sm text-primary-500">{project.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-600">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner
      headline="Have a project in mind?"
      ctaText="Let's Talk"
      ctaHref="/contact"
      variant="accent"
    />
  </main>
  <Footer />
</BaseLayout>
